{
  "expo": {
    "name": "vaultvoss",
    "slug": "vaultvoss",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/vaultvoss-white.png",
    "scheme": "vaultvoss",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/2c15d7e6-e24e-40c7-bc3e-70d8c828cef2"
    },
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/images/Light.png",
        "dark": "./assets/images/Dark.png",
        "tinted": "./assets/images/Tinted.png"
      },
      "bundleIdentifier": "com.codydematth.vaultvoss"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/vaultvoss.png"
      },
      "permissions": ["android.permission.SCHEDULE_EXACT_ALARM"],
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.codydematth.vaultvoss",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/vaultvoss.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/vaultvoss-white.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "./plugins/withJitpack",
      "./plugins/withAndroidSwitcherSecurity",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.447105374706-nb40amb89c2ht6tjn9jsv9uqfei4l8nf"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c15d7e6-e24e-40c7-bc3e-70d8c828cef2"
      }
    }
  }
}
